  m_Script: {fileID: 11500000, guid: 44ed88e18cd8d4322aa8f076510cb765, type: 3}
  m_Name: Cutscene_world6
  m_EditorClassIdentifier: CrowdDefense::CrowdDefense.Data.CutsceneDef
  id: world6
  titleKey: L'Apocalypse - Le Dernier Rempart
  lines:
  - speaker: Narrateur
    textKey: Les cendres de l'Apocalypse recouvrent Milan Park. Le ciel est rouge
      sang.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Une armee de survivants endoctrines deferlent depuis les ruines fumantes.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: L'Apocalypse en personne mene ses troupes - une entite que personne
      n'a jamais vaincue.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: C'est le dernier rempart. Si tu tombes, il ne reste plus rien.
    portrait: {fileID: 0}
    side: 0
