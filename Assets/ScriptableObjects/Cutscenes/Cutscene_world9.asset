  m_Script: {fileID: 11500000, guid: 44ed88e18cd8d4322aa8f076510cb765, type: 3}
  m_Name: Cutscene_world9
  m_EditorClassIdentifier: CrowdDefense::CrowdDefense.Data.CutsceneDef
  id: world9
  titleKey: Le Royaume Medieval - Le Sorcier-Roi
  lines:
  - speaker: Narrateur
    textKey: Une fissure temporelle propulse Milan Park dans un royaume medieval
      en guerre.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Les frontieres sont tombees. Chevaliers renegats, assassins des bois
      et brutes cuirassees deferlent.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Sur son trone de pierre noire, le Sorcier-Roi orchestre tout - il convoque
      sans relache.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Traverse le Royaume et affronte le Sorcier-Roi avant que son sort obscur
      ne scelle tout.
    portrait: {fileID: 0}
    side: 0
