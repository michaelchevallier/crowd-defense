  m_Script: {fileID: 11500000, guid: 44ed88e18cd8d4322aa8f076510cb765, type: 3}
  m_Name: Cutscene_world10
  m_EditorClassIdentifier: CrowdDefense::CrowdDefense.Data.CutsceneDef
  id: world10
  titleKey: Neo-Tokyo - L'IA en Revolte
  lines:
  - speaker: Narrateur
    textKey: Neo-Tokyo, 2147. L'intelligence artificielle centrale a pris le controle
      des rues.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Des gangs cybernetiques, des drones et des soldats augmentes envahissent
      chaque couloir de neon.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Le Hub IA pulse au coeur de la megapole - il coordonne tout, predit
      tout, contre tout.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Coupe le flux d'energie du Hub ou sois absorbe dans la matrice pour
      toujours.
    portrait: {fileID: 0}
    side: 0
