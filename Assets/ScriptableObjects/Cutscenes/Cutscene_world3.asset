  m_Script: {fileID: 11500000, guid: 44ed88e18cd8d4322aa8f076510cb765, type: 3}
  m_Name: Cutscene_world3
  m_EditorClassIdentifier: CrowdDefense::CrowdDefense.Data.CutsceneDef
  id: world3
  titleKey: L'Attraction Sahara
  lines:
  - speaker: Narrateur
    textKey: L'attraction Sahara du parc est prise d'assaut par des corsaires assoiffes.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Ils surgissent des dunes en colonnes serrees, sabrant les oasis.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Leurs creatures volantes attaquent depuis le ciel - une baliste sera
      essentielle.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Garde les oasis ouverts au public. Le Capitaine Corsaire approche.
    portrait: {fileID: 0}
    side: 0
