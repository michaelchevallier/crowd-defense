  m_Script: {fileID: 11500000, guid: 44ed88e18cd8d4322aa8f076510cb765, type: 3}
  m_Name: Cutscene_world7
  m_EditorClassIdentifier: CrowdDefense::CrowdDefense.Data.CutsceneDef
  id: world7
  titleKey: L'Espace - Hors Atmosphere !
  lines:
  - speaker: Narrateur
    textKey: Une anomalie gravitationnelle propulse Milan Park hors de l'atmosphere
      terrestre.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Dans le vide spatial, des entites cosmiques surgissent de toutes parts.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Les etoiles sont des ennemis. Les asteroides cachent des escouades entieres.
    portrait: {fileID: 0}
    side: 0
  - speaker: Narrateur
    textKey: Defends tes positions dans l'espace profond - l'Entite Galactique approche.
    portrait: {fileID: 0}
    side: 0
