<ui:UXML xmlns:ui="UnityEngine.UIElements"
         xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements"
         editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../UIElementsSchema/UIElements.xsd">
    <ui:VisualElement name="summary-root" class="summary-root hidden">
        <ui:VisualElement class="summary-panel">
            <ui:Label text="VICTOIRE" name="summary-title" class="summary-title" />
            <ui:Label text="★★★" name="summary-stars" class="summary-stars" />
            <ui:Label text="" name="summary-stats" class="summary-stats" />
            <ui:Label text="" name="summary-gems" class="summary-gems" />
            <ui:VisualElement class="summary-buttons">
                <ui:Button text="Recommencer" name="summary-btn-retry" class="summary-btn" />
                <ui:Button text="Suivant" name="summary-btn-next" class="summary-btn summary-btn-next" />
                <ui:Button text="Carte du monde" name="summary-btn-menu" class="summary-btn summary-btn-secondary" />
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
